        <form method="POST" action="/developer/register" enctype="multipart/form-data" class="form-card">
            @csrf

            <section class="form-section">
                <div class="section-header">
                    <strong>Account Details</strong>
                    <span>Your login credentials</span>
                </div>

                <div class="form-grid form-grid-2">
                    <div class="field-group">
                        <label for="name">Full Name <span>*</span></label>
                        <input id="name" class="input-field" type="text" name="name" value="{{ old('name') }}" required>
                    </div>

                    <div class="field-group">
                        <label for="email">Email <span>*</span></label>
                        <input id="email" class="input-field" type="email" name="email" value="{{ old('email') }}" required>
                    </div>

                    <div class="field-group">
                        <label for="password">Password <span>*</span></label>
                        <input id="password" class="input-field" type="password" name="password" required>
                    </div>

                    <div class="field-group">
                        <label for="password_confirmation">Confirm Password <span>*</span></label>
                        <input id="password_confirmation" class="input-field" type="password" name="password_confirmation" required>
                    </div>
                </div>
            </section>

            <section class="form-section">
                <div class="section-header">
                    <strong>Profile Information</strong>
                    <span>Tell us more about your developer profile</span>
                </div>

                <div class="form-grid">
                    <div class="field-group">
                        <label for="bio">Bio <span>(optional)</span></label>
                        <textarea id="bio" class="textarea-field" name="bio">{{ old('bio') }}</textarea>
                    </div>

                    <div class="field-group">
                        <label for="linkedin_url">LinkedIn Profile <span>(optional)</span></label>
                        <input id="linkedin_url" class="input-field" type="url" name="linkedin_url" value="{{ old('linkedin_url') }}" placeholder="https://">
                    </div>

                    <div class="field-group">
                        <label for="portfolio_url">Portfolio URL <span>(optional)</span></label>
                        <input id="portfolio_url" class="input-field" type="url" name="portfolio_url" value="{{ old('portfolio_url') }}" placeholder="https://">
                    </div>

                    <div class="field-group file-field">
                        <label for="profile_picture">Profile Picture <span>(optional)</span></label>
                        <input id="profile_picture" type="file" name="profile_picture">
                    </div>
                </div>
            </section>

            <div class="button-row">
                <button type="submit" class="button-primary">Create Developer Account</button>
            </div>
        </form>

        <p class="footer-note">Your data is encrypted and secure.</p>
    </div>
</body>
</html>